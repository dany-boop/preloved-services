{
  "$schema": "https://www.krakend.io/schema/v2.6/config.json",
  "version": 3,
  "name": "AntiGravity API Gateway",
  "port": 8080,
  "timeout": "10s",
  "cache_ttl": "300s",

  "extra_config": {
    "telemetry/logging": {
      "level": "DEBUG",
      "prefix": "[KRAKEND]",
      "syslog": false,
      "stdout": true
    },
    "telemetry/metrics": {
      "collection_time": "60s",
      "listen_address": ":8090"
    },
    "security/cors": {
      "allow_origins": ["http://localhost:3000", "http://localhost:3001"],
      "allow_methods": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"],
      "allow_headers": ["Authorization", "Content-Type", "X-Correlation-ID"],
      "expose_headers": ["X-Correlation-ID"],
      "max_age": "12h",
      "allow_credentials": true
    }
  },

  "endpoints": [

    {
      "endpoint": "/api/v1/auth/register",
      "method": "POST",
      "timeout": "15s",
      "backend": [{
        "url_pattern": "/register",
        "host": ["http://auth-service:8001"],
        "method": "POST"
      }]
    },

    {
      "endpoint": "/api/v1/auth/login",
      "method": "POST",
      "timeout": "10s",
      "backend": [{
        "url_pattern": "/login",
        "host": ["http://auth-service:8001"],
        "method": "POST"
      }]
    },

    {
      "endpoint": "/api/v1/auth/refresh",
      "method": "POST",
      "backend": [{
        "url_pattern": "/refresh",
        "host": ["http://auth-service:8001"],
        "method": "POST"
      }]
    },

    {
      "endpoint": "/api/v1/auth/logout",
      "method": "POST",
      "extra_config": {
        "auth/validator": {
          "alg": "HS256",
          "jwk_local_path": "./jwk.json",
          "disable_jwk_security": true
        }
      },
      "backend": [{
        "url_pattern": "/logout",
        "host": ["http://auth-service:8001"],
        "method": "POST"
      }]
    },

    {
      "endpoint": "/api/v1/users/me",
      "method": "GET",
      "extra_config": {
        "auth/validator": {
          "alg": "HS256",
          "jwk_local_path": "./jwk.json",
          "disable_jwk_security": true
        }
      },
      "backend": [{
        "url_pattern": "/me",
        "host": ["http://user-service:8002"],
        "method": "GET"
      }]
    },

    {
      "endpoint": "/api/v1/users/{id}",
      "method": "GET",
      "backend": [{
        "url_pattern": "/users/{id}",
        "host": ["http://user-service:8002"],
        "method": "GET"
      }]
    },

    {
      "endpoint": "/api/v1/chat/rooms",
      "method": "GET",
      "backend": [{
        "url_pattern": "/rooms",
        "host": ["http://chat-service:8003"],
        "method": "GET"
      }]
    },

    {
      "endpoint": "/api/v1/search",
      "method": "GET",
      "backend": [{
        "url_pattern": "/search",
        "host": ["http://search-service:8005"],
        "method": "GET"
      }]
    },

    {
      "endpoint": "/api/v1/ai/recommend",
      "method": "POST",
      "extra_config": {
        "qos/ratelimit/router": {
          "max_rate": 10,
          "client_max_rate": 2,
          "strategy": "ip"
        }
      },
      "backend": [{
        "url_pattern": "/recommend",
        "host": ["http://ai-service:8006"],
        "method": "POST"
      }]
    },

    {
      "endpoint": "/api/v1/media/upload",
      "method": "POST",
      "timeout": "60s",
      "backend": [{
        "url_pattern": "/upload",
        "host": ["http://media-service:8007"],
        "method": "POST"
      }]
    }

  ]
}
