# ============================================================
# AntiGravity Backend — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git!
# ============================================================

# ── PostgreSQL ──────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=local_dev_password
POSTGRES_DB=preloved
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── MongoDB ─────────────────────────────────────
MONGO_USER=aguser
MONGO_PASSWORD=change_me_in_production
MONGO_DB=antigravity
MONGO_HOST=localhost
MONGO_PORT=27017

# ── Redis ───────────────────────────────────────
REDIS_PASSWORD=change_me_in_production
REDIS_HOST=localhost
REDIS_PORT=6379

# ── RabbitMQ ────────────────────────────────────
RABBITMQ_USER=aguser
RABBITMQ_PASSWORD=change_me_in_production
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_VHOST=antigravity

# ── MinIO (Object Storage) ──────────────────────
MINIO_USER=agadmin
MINIO_PASSWORD=change_me_in_production
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_BUCKET_MEDIA=media
MINIO_BUCKET_DOCS=documents

# ── Elasticsearch ───────────────────────────────
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# ── JWT ─────────────────────────────────────────
JWT_SECRET=super_secret_key_change_in_production_min_32_chars
JWT_ACCESS_EXPIRY=15m       # Access token: 15 minutes
JWT_REFRESH_EXPIRY=7d       # Refresh token: 7 days

# ── Service Ports ───────────────────────────────
AUTH_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
CHAT_SERVICE_PORT=8003
NOTIFICATION_SERVICE_PORT=8004
SEARCH_SERVICE_PORT=8005
AI_SERVICE_PORT=8006
MEDIA_SERVICE_PORT=8007

# ── AI APIs ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Email (for notification service) ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=app_password_here
SMTP_FROM=noreply@antigravity.com

# ── Monitoring ──────────────────────────────────
GRAFANA_PASSWORD=admin
JAEGER_ENDPOINT=http://localhost:4318/v1/traces

# ── App ─────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_LOG_LEVEL=debug          # debug | info | warn | error
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
